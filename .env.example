# LLM world quality (optional — use Off when offline)
MMP_LLM_MODE=off
# MMP_LLM_MODE=openai
# MMP_LLM_MODE=ollama

# OpenAI (when MMP_LLM_MODE=openai)
OPENAI_API_KEY=

# Model override (defaults: gpt-4o-mini / llama3.2)
# MMP_LLM_MODEL=gpt-4o-mini

# Ollama base URL (when MMP_LLM_MODE=ollama)
# MMP_OLLAMA_URL=http://localhost:11434
